# 1 - تجهيز الملفات
mkdir dags, script

# 2 - تصحيح الـ entrypoint
(Get-Content .\script\entrypoint.sh -Raw) -replace "`r`n", "`n" | Set-Content .\script\entrypoint.sh -NoNewline

# 3 - تصحيح الـ requirements.txt
Set-Content .\requirements.txt -Value "apache-airflow==2.6.0`nkafka-python==2.0.2`nrequests==2.31.0`nurllib3==2.0.7`ncertifi==2024.2.2`napache-airflow-providers-apache-kafka==1.3.0" -Encoding UTF8

# 4 - تشغيل Docker
docker compose up -d

# 5 - تشغيل الـ scheduler
docker compose up -d scheduler

# 6 - تأكد إن Kafka استلم البيانات
docker exec -it broker kafka-topics --list --bootstrap-server localhost:9092

# 7 - إصلاح permissions الـ Spark
docker exec -it --user root spark-master mkdir -p /home/spark/.ivy2/cache
docker exec -it --user root spark-master chmod -R 777 /home/spark/.ivy2

# 8 - نسخ spark_stream.py للـ container
docker cp spark_stream.py spark-master:/opt/spark/spark_stream.py

# 9 - تثبيت cassandra-driver
docker exec -it --user root spark-master pip install cassandra-driver

# 10 - تشغيل Spark
docker exec -it spark-master /opt/spark/bin/spark-submit --packages com.datastax.spark:spark-cassandra-connector_2.12:3.4.1,org.apache.spark:spark-sql-kafka-0-10_2.12:3.4.1 /opt/spark/spark_stream.py

# 11 - التحقق من البيانات في Cassandra
docker exec -it cassandra cqlsh -u cassandra -p cassandra




SELECT * FROM spark_streams.created_users LIMIT 10;

COPY spark_streams.created_users TO '/tmp/users.csv' WITH HEADER = TRUE;
exit


# 12 - تنزيل الـ CSV على جهازك
docker cp cassandra:/tmp/users.csv .\users.csv

# 13 - فتح الملف
start .\users.csv


